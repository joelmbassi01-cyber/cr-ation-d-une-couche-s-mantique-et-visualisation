        "partitions": [
          {
            "name": "FactInternetSales",
            "dataView": "full",
            "source": {
              "type": "query",
              "query": " \t\t\t\tSELECT [dbo].[FactInternetSales].*   FROM [dbo].[FactInternetSales] ",
              "dataSource": "SqlServer KAIZER AdventureWorksDW2020"
            }
          }
        ],
        "measures": [
          {
            "name": "Charges freight cible",
            "expression": " 700000"
          },
          {
            "name": "Charges Freight",
            "expression": "SUM([Freight])"
          },
          {
            "name": "Coût produit",
            "expression": "SUM([TotalProductCost])"
          },
          {
            "name": "Coût total (+freight)",
            "expression": " [Coût produit]+[Charges Freight]",
            "kpi": {
              "targetExpression": "'FactInternetSales'[Coût total cible]",
              "statusGraphic": "Traffic Light - Single",
              "statusExpression": [
                "var x='FactInternetSales'[Coût total (+freight)]/'FactInternetSales'[_Coût total (+freight) Goal] return",
                "            if(ISBLANK(x),BLANK(),",
                "                    If(x<0.29,1,",
                "\t                If(x<0.81,0,-1)",
                "                )",
                "            )",
                "            "
              ],
              "annotations": [
                {
                  "name": "GoalType",
                  "value": "Measure"
                },
                {
                  "name": "KpiStatusType",
                  "value": "Linear"
                },
                {
                  "name": "KpiThresholdType",
                  "value": "Percentage"
                },
                {
                  "name": "KpiThresholdOrdering",
                  "value": "Descending"
                },
                {
                  "name": "KpiThresholdCount",
                  "value": "2"
                },
                {
                  "name": "KpiThreshold_0",
                  "value": "81"
                },
                {
                  "name": "KpiThreshold_1",
                  "value": "29"
                }
              ]
            }
          },
          {
            "name": "Ventes cibles",
            "expression": " 35000000"
          },
          {
            "name": "Ventes",
            "expression": "SUM([SalesAmount])"
          },
          {
            "name": "Profit",
            "expression": " [Ventes]-[Coût produit]"
          },
